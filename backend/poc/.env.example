# ===== Agent Hub POC 配置 =====
# 复制为 .env 并填入真实值;.env 不进 git(生产安全)。

# LLM(OpenAI 兼容 endpoint)
LLM_BASE_URL=http://192.168.2.220:3000/v1
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=deepseek-v4-flash
# 推理模型需较大 token 预算(reasoning 占用)
LLM_MAX_TOKENS=4000

# Sandbox(POC 用 python slim;真 sandbox 镜像待接)
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_GPU=false
